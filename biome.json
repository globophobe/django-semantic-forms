{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "files": {
    "includes": ["semantic_forms/static/semantic_forms/**/*.js"]
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "rules": {
      "complexity": {
        "useArrowFunction": "off",
        "useOptionalChain": "off"
      },
      "correctness": {
        "noUnusedVariables": "off"
      },
      "style": {
        "useTemplate": "off"
      },
      "suspicious": {
        "noRedundantUseStrict": "off"
      }
    }
  },
  "javascript": {
    "globals": ["getCalendarOptions", "gettext", "interpolate", "ngettext", "pgettext"]
  }
}
